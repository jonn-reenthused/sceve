-- *** stubs for extern functions — replace with real implementations ***

-- scv_print_char: arg row arrives in (scv_print_char__arg_row)
-- scv_print_char: arg col arrives in (scv_print_char__arg_col)
-- scv_print_char: arg ch arrives in (scv_print_char__arg_ch)
@fn_scv_print_char
    mvi h,0x30
    mvi l,0x40
    mov b,(scv_print_char__arg_row)
@scv_print_char_row_loop
    mov a,b
    nei a,0
    jr scv_print_char_col_step
    adi l,0x20
    aci h,0
    dcr b
    jre scv_print_char_row_loop
@scv_print_char_col_step
    mov a,(scv_print_char__arg_col)
    adi a,0x03
    add l,a
    aci h,0
    mov a,(scv_print_char__arg_ch)
    stax (hl)
    ret

-- scv_print_string: arg x arrives in (scv_print_string__arg_x)
-- scv_print_string: arg y arrives in (scv_print_string__arg_y)
-- scv_print_string: arg str arrives in (scv_print_string__arg_str)
@fn_scv_print_string
    mvi a,0x20
    mov (scv_print_string__tmp_guard),a
@scv_print_string_loop
    mov a,(scv_print_string__tmp_guard)
    eqi a,0
    skz
    jmp scv_print_string_check_char
    ret
@scv_print_string_check_char
    ldax (de)
    mov b,a
    eqi a,0
    skz
    jmp scv_print_string_print_char
    ret
@scv_print_string_print_char
    mov a,b
    mov (scv_print_char__arg_ch),a
    mov a,(scv_print_string__arg_x)
    mov (scv_print_char__arg_row),a
    mov a,(scv_print_string__arg_y)
    mov (scv_print_char__arg_col),a
    call fn_scv_print_char
    inx de
    mov a,(scv_print_string__arg_y)
    adi a,0x01
    mov (scv_print_string__arg_y),a
    mov a,(scv_print_string__tmp_guard)
    adi a,0xFF
    mov (scv_print_string__tmp_guard),a
    jmp scv_print_string_loop

@fn_scv_read_pad1
    mvi a,0xFD
    mov pa,a
    nop
    mov a,pb
    mov a,pb
    mov (scv_pad1_state),a
    ret

@fn_scv_read_pad2
    mvi a,0xFE
    mov pa,a
    nop
    mov a,pb
    mov a,pb
    mov (scv_pad2_state),a
    ret

@fn_scv_wait_vblank
@scv_wait_vblank_wait
    skit f2
    jr scv_wait_vblank_wait
    ret

-- sprintf: arg dst arrives in (sprintf__arg_dst)
-- sprintf: arg fmt arrives in (sprintf__arg_fmt)
-- sprintf: arg value arrives in (sprintf__arg_value)
@fn_sprintf
    mvi a,0x00
    mov (sprintf__tmp_count),a
@sprintf_loop
    ldaxi (hl)
    eqi a,0
    skz
    jmp sprintf_loop_continue
    mvi a,0x00
    stax (de)
    mov a,(sprintf__tmp_count)
    ret
@sprintf_loop_continue
    eqi a,0x25
    skz
    jmp sprintf_not_percent
    jmp sprintf_handle_percent
@sprintf_not_percent
    ldaxi (hl)
    stax (de)
    inx de
    mov a,(sprintf__tmp_count)
    adi a,0x01
    mov (sprintf__tmp_count),a
    jmp sprintf_loop
@sprintf_handle_percent
    ldaxi (hl)
    eqi a,0
    skz
    jmp sprintf_check_percent_code
    mvi a,0x00
    stax (de)
    mov a,(sprintf__tmp_count)
    ret
@sprintf_check_percent_code
    eqi a,0x25
    skz
    jmp sprintf_check_format_code
    mvi a,0x25
    stax (de)
    inx de
    mov a,(sprintf__tmp_count)
    adi a,0x01
    mov (sprintf__tmp_count),a
    inx hl
    jmp sprintf_loop
@sprintf_check_format_code
    eqi a,0x64
    skz
    jmp sprintf_check_unsigned_fmt
    jmp sprintf_emit_decimal
@sprintf_check_unsigned_fmt
    eqi a,0x75
    skz
    jmp sprintf_unknown_format
    jmp sprintf_emit_decimal
@sprintf_unknown_format
    mvi a,0x3F
    stax (de)
    inx de
    mov a,(sprintf__tmp_count)
    adi a,0x01
    mov (sprintf__tmp_count),a
    jmp sprintf_loop
@sprintf_emit_decimal
    mov a,(sprintf__arg_value)
    mov (sprintf__tmp_rem),a
    mvi a,0x00
    mov (sprintf__tmp_hundreds),a
    mov (sprintf__tmp_tens),a
    mov (sprintf__tmp_started),a
@sprintf_hundreds_loop
    mov a,(sprintf__tmp_rem)
    mvi b,0x64
    sub a,b
    skc
    jmp sprintf_hundreds_apply
    jmp sprintf_hundreds_done
@sprintf_hundreds_apply
    mov (sprintf__tmp_rem),a
    mov a,(sprintf__tmp_hundreds)
    adi a,0x01
    mov (sprintf__tmp_hundreds),a
    jmp sprintf_hundreds_loop
@sprintf_hundreds_done
@sprintf_tens_loop
    mov a,(sprintf__tmp_rem)
    mvi b,0x0A
    sub a,b
    skc
    jmp sprintf_tens_apply
    jmp sprintf_tens_done
@sprintf_tens_apply
    mov (sprintf__tmp_rem),a
    mov a,(sprintf__tmp_tens)
    adi a,0x01
    mov (sprintf__tmp_tens),a
    jmp sprintf_tens_loop
@sprintf_tens_done
    mov a,(sprintf__tmp_hundreds)
    eqi a,0
    skz
    jmp sprintf_skip_hundreds
    mov a,(sprintf__tmp_hundreds)
    adi a,0x30
    stax (de)
    inx de
    mov a,(sprintf__tmp_count)
    adi a,0x01
    mov (sprintf__tmp_count),a
    mvi a,0x01
    mov (sprintf__tmp_started),a
@sprintf_skip_hundreds
    mov a,(sprintf__tmp_started)
    eqi a,0
    skz
    jmp sprintf_emit_tens_check
    mov a,(sprintf__tmp_tens)
    eqi a,0
    skz
    jmp sprintf_skip_tens
@sprintf_emit_tens_check
    mov a,(sprintf__tmp_tens)
    adi a,0x30
    stax (de)
    inx de
    mov a,(sprintf__tmp_count)
    adi a,0x01
    mov (sprintf__tmp_count),a
@sprintf_skip_tens
    mov a,(sprintf__tmp_rem)
    adi a,0x30
    stax (de)
    inx de
    mov a,(sprintf__tmp_count)
    adi a,0x01
    mov (sprintf__tmp_count),a
    jmp sprintf_loop

-- strlen: arg str arrives in (strlen__arg_str)
@fn_strlen
    mvi b,0x00
@strlen_loop
    ldax (de)
    eqi a,0
    skz
    jmp strlen_continue_strlen
    mov a,b
    ret
@strlen_continue_strlen
    inx de
    mov a,b
    adi a,0x01
    mov b,a
    jmp strlen_loop

-- C const/static const ROM data

-- label_p1
@label_p1__rom
    dc.b 0x50, 0x31, 0x00

-- label_p2
@label_p2__rom
    dc.b 0x50, 0x32, 0x00

-- fmt_pad
@fmt_pad__rom
    dc.b 0x52, 0x41, 0x57, 0x3D, 0x25, 0x75, 0x00


writebin(filename .. '.bin')
