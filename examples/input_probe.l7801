-- ROM data blocks (const/static const arrays)
-- label_p1 -> @label_p1__rom (3 bytes)
-- label_p2 -> @label_p2__rom (3 bytes)
-- fmt_pad -> @fmt_pad__rom (7 bytes)

@main
    di
    lxi sp,0xFFF0
    ei
    calt 0x8C
    lxi hl,0x3400
    mvi a,0xF4
    staxi (hl)
    mvi a,0x00
    staxi (hl)
    staxi (hl)
    mvi a,0xF1
    stax (hl)
    call fn_main
@halt_loop
    jr halt_loop

@fn_main
    mvi a,0x02
    mov (scv_print_string__arg_x),a
    mvi a,0x02
    mov (scv_print_string__arg_y),a
    lxi de,label_p1__rom
    call fn_scv_print_string
    mvi a,0x02
    mov (scv_print_string__arg_x),a
    mvi a,0x03
    mov (scv_print_string__arg_y),a
    lxi de,label_p2__rom
    call fn_scv_print_string
    mvi a,0x02
    mov (main__title_len),a
    mvi a,0x02
    mov (scv_print_char__arg_row),a
    mvi a,0x02
    mov b,a
    mov a,(main__title_len)
    add a,b
    mov (scv_print_char__arg_col),a
    mvi a,0x3A
    mov (scv_print_char__arg_ch),a
    call fn_scv_print_char
    mvi a,0x03
    mov (scv_print_char__arg_row),a
    mvi a,0x02
    mov b,a
    mov a,(main__title_len)
    add a,b
    mov (scv_print_char__arg_col),a
    mvi a,0x3A
    mov (scv_print_char__arg_ch),a
    call fn_scv_print_char
@while_start_2
    mvi a,0x01
    eqi a,0
    jr while_body_4
    jmp while_end_3
@while_body_4
    call fn_scv_wait_vblank
    call fn_scv_read_pad1
