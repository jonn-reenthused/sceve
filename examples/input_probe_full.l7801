    mov (scv_print_char__arg_row),a
    mvi a,0x0B
    mov (scv_print_char__arg_col),a
    mvi a,0x2E
    mov (scv_print_char__arg_ch),a
    call fn_scv_print_char
@if_end_96
    mov a,(scv_pad1_state)
    mov (sprintf__arg_value),a
    lxi de,line_out__ram_0
    lxi hl,fmt_j1__rom
    call fn_sprintf
    mvi a,0x0E
    mov (scv_print_string__arg_x),a
    mvi a,0x01
    mov (scv_print_string__arg_y),a
    lxi de,line_out__ram_0
    call fn_scv_print_string
    mov a,(scv_pad2_state)
    mov (sprintf__arg_value),a
    lxi de,line_out__ram_0
    lxi hl,fmt_j2__rom
    call fn_sprintf
    mvi a,0x0E
    mov (scv_print_string__arg_x),a
    mvi a,0x02
    mov (scv_print_string__arg_y),a
    lxi de,line_out__ram_0
    call fn_scv_print_string
    mov a,(main__key0)
    mov (sprintf__arg_value),a
    lxi de,line_out__ram_0
    lxi hl,fmt_k0__rom
    call fn_sprintf
    mvi a,0x00
    mov (scv_print_string__arg_x),a
    mvi a,0x05
    mov (scv_print_string__arg_y),a
    lxi de,line_out__ram_0
    call fn_scv_print_string
    mov a,(main__key1)
    mov (sprintf__arg_value),a
    lxi de,line_out__ram_0
    lxi hl,fmt_k1__rom
    call fn_sprintf
    mvi a,0x00
    mov (scv_print_string__arg_x),a
    mvi a,0x06
    mov (scv_print_string__arg_y),a
    lxi de,line_out__ram_0
    call fn_scv_print_string
    mov a,(main__key2)
    mov (sprintf__arg_value),a
    lxi de,line_out__ram_0
    lxi hl,fmt_k2__rom
    call fn_sprintf
    mvi a,0x00
    mov (scv_print_string__arg_x),a
    mvi a,0x07
    mov (scv_print_string__arg_y),a
    lxi de,line_out__ram_0
    call fn_scv_print_string
    mov a,(main__key3)
    mov (sprintf__arg_value),a
    lxi de,line_out__ram_0
    lxi hl,fmt_k3__rom
    call fn_sprintf
    mvi a,0x00
    mov (scv_print_string__arg_x),a
    mvi a,0x08
    mov (scv_print_string__arg_y),a
    lxi de,line_out__ram_0
    call fn_scv_print_string
    mov a,(main__key4)
    mov (sprintf__arg_value),a
    lxi de,line_out__ram_0
    lxi hl,fmt_k4__rom
    call fn_sprintf
    mvi a,0x00
    mov (scv_print_string__arg_x),a
    mvi a,0x09
    mov (scv_print_string__arg_y),a
    lxi de,line_out__ram_0
    call fn_scv_print_string
    mov a,(main__key5)
    mov (sprintf__arg_value),a
    lxi de,line_out__ram_0
