-- ROM data blocks (const/static const arrays)
-- label_bits -> @label_bits__rom (9 bytes)
-- label_j1 -> @label_j1__rom (4 bytes)
-- label_j2 -> @label_j2__rom (4 bytes)
-- label_keys -> @label_keys__rom (12 bytes)
-- fmt_j1 -> @fmt_j1__rom (7 bytes)
-- fmt_j2 -> @fmt_j2__rom (7 bytes)
-- fmt_k0 -> @fmt_k0__rom (6 bytes)
-- fmt_k1 -> @fmt_k1__rom (6 bytes)
-- fmt_k2 -> @fmt_k2__rom (6 bytes)
-- fmt_k3 -> @fmt_k3__rom (6 bytes)
-- fmt_k4 -> @fmt_k4__rom (6 bytes)
-- fmt_k5 -> @fmt_k5__rom (6 bytes)

@main
    di
    lxi sp,0xFFF0
    ei
    calt 0x8C
    lxi hl,0x3400
    mvi a,0xF4
    staxi (hl)
    mvi a,0x00
    staxi (hl)
    staxi (hl)
    mvi a,0xF1
    stax (hl)
    call fn_main
@halt_loop
    jr halt_loop

@fn_main
    mvi a,0x04
    mov (scv_print_string__arg_x),a
    mvi a,0x00
    mov (scv_print_string__arg_y),a
    lxi de,label_bits__rom
    call fn_scv_print_string
    mvi a,0x00
    mov (scv_print_string__arg_x),a
    mvi a,0x01
    mov (scv_print_string__arg_y),a
    lxi de,label_j1__rom
    call fn_scv_print_string
    mvi a,0x00
    mov (scv_print_string__arg_x),a
    mvi a,0x02
    mov (scv_print_string__arg_y),a
    lxi de,label_j2__rom
    call fn_scv_print_string
    mvi a,0x00
    mov (scv_print_string__arg_x),a
    mvi a,0x04
    mov (scv_print_string__arg_y),a
    lxi de,label_keys__rom
    call fn_scv_print_string
@while_start_2
    mvi a,0x01
    eqi a,0
    jr while_body_4
    jmp while_end_3
@while_body_4
    call fn_scv_wait_vblank
    call fn_scv_read_pad1
    call fn_scv_read_pad2
    mvi a,0xFB
    mov (scv_read_input_scan__arg_pa_mask),a
    call fn_scv_read_input_scan
    mov (main__key0),a
