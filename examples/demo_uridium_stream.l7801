@fn_scv_set_hw_sprite_raw
    mov a,(scv_set_hw_sprite_raw__arg_id)
    add a,a
    add a,a
    mov l,a
    mvi a,0x32
    aci a,0
    mov h,a
    mov a,(scv_set_hw_sprite_raw__arg_y)
    staxi (hl)
    mov a,(scv_set_hw_sprite_raw__arg_color)
    staxi (hl)
    mov a,(scv_set_hw_sprite_raw__arg_x)
    staxi (hl)
    mov a,(scv_set_hw_sprite_raw__arg_pattern)
    ani a,0x7F
    stax (hl)
    ret

