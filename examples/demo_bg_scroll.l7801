local scv_print_string__arg_y = 0xFFAA
local scv_draw_bg_tile__arg_row = 0xFFAB
local scv_draw_bg_tile__arg_col = 0xFFAC
local scv_draw_bg_tile__arg_tile_id = 0xFFAD
local scv_set_bg_scroll__arg_scroll_x = 0xFFAE
local scv_set_bg_scroll__arg_scroll_y = 0xFFAF
